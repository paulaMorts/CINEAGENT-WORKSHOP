# OMDb API key for movie/TV series lookups
OMDB_API_KEY=your_omdb_api_key_here

# AWS region for Amazon Bedrock
AWS_REGION=us-east-1

# Amazon Bedrock model identifier
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# AgentCore Runtime ARN (from deploy_agent.py output)
AGENTCORE_RUNTIME_ARN=your_agentcore_runtime_arn_here

# AgentCore region
AGENTCORE_REGION=us-east-1

# AgentCore Memory resource ID (from setup_memory.py output)
MEMORY_ID=your_memory_id_here

# AgentCore Gateway MCP endpoint URL (from setup_gateway.py output)
GATEWAY_URL=your_gateway_url_here

# AgentCore Gateway access token (from setup_gateway.py output)
GATEWAY_ACCESS_TOKEN=your_gateway_access_token_here
